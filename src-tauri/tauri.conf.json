{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EasyVault",
  "version": "0.2.0",
  "identifier": "com.niclas.easyvault",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "EasyVault",
        "width": 1500,
        "height": 980,
        "minWidth": 1200,
        "minHeight": 760,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/NiclasAssendelft/EasyVault-desktop/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY4QTBCOUJGMEJGNjdEQjcKUldTM2ZmWUx2N21nK0Z4YVg5WDZVOWVGbXpuenRNcTVBbmFlVDZWUkE4MTNDQ0NBRGRhU085TEsK"
    }
  }
}
